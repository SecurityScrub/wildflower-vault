# ─── Database ─────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/wildflowervault"

# ─── NextAuth ──────────────────────────────────────────────
NEXTAUTH_URL="https://yourdomain.com"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# ─── Square ────────────────────────────────────────────────
# These can also be managed via the Admin portal Settings page
# and will be stored encrypted in the database.
SQUARE_ACCESS_TOKEN=""
SQUARE_APPLICATION_ID=""
SQUARE_LOCATION_ID=""
SQUARE_ENVIRONMENT="sandbox"          # sandbox | production
SQUARE_WEBHOOK_SIGNATURE_KEY=""

# ─── ZeptoMail HTTP API ─────────────────────────────────────
# All transactional emails (bookings, inquiries, consultations, MFA, lead
# acks) go through the ZeptoMail Send Mail HTTP API. SMTP is intentionally
# not supported because Railway blocks outbound SMTP.
# Get the Send Mail Token from ZeptoMail console → Mail Agents → Setup Info → API.
# Paste only the token value (without the "Zoho-enczapikey " prefix).
ZEPTOMAIL_API_URL="https://api.zeptomail.com/v1.1/email"
ZEPTOMAIL_API_TOKEN=""
ZEPTOMAIL_FROM_EMAIL="noreply@thewildflowervault.com"
ZEPTOMAIL_FROM_NAME="The Wild Flower Vault"

# ─── Cloudflare Turnstile ──────────────────────────────────
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""
# Set to "1" to bypass Turnstile entirely (skips client widget gate + server
# verification). Use for staging/testing or when the keys are misconfigured.
# Leave blank in production to enforce.
TURNSTILE_DISABLED=""

# ─── App Config ────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="https://thewildflowervault.com"
NEXT_PUBLIC_BUSINESS_NAME="The Wild Flower Vault"
ADMIN_EMAIL="admin@thewildflowervault.com"

# ─── Encryption (for DB-stored secrets) ───────────────────
ENCRYPTION_KEY="generate-32-byte-hex-key"
