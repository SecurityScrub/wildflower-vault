generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  CUSTOMER
  ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  DEPOSIT_PAID
  PAID
  CANCELLED
  REFUNDED
  COMPLETED
}

enum PriceType {
  PER_EVENT
  PER_DAY
  PER_HOUR
}

enum LeadStatus {
  NEW
  CONTACTED
  CONSULTATION_BOOKED
  PROPOSAL_SENT
  BOOKED
  ACTIVE
  COMPLETED
  LOST
}

enum NoteType {
  NOTE
  CALL
  EMAIL
  MEETING
  SMS
}

enum WeddingStatus {
  PLANNING
  ACTIVE
  COMPLETED
  CANCELLED
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  DONE
  SKIPPED
}

enum VendorStatus {
  CONSIDERING
  CONTACTED
  PROPOSAL
  BOOKED
  PAID
  DECLINED
}

enum RSVPStatus {
  PENDING
  YES
  NO
  MAYBE
}

enum ConsultationStatus {
  REQUESTED
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

// ─── Auth (NextAuth) ──────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Users ────────────────────────────────────────────────────────────────────

model User {
  id              String     @id @default(cuid())
  email           String     @unique
  name            String?
  phone           String?
  passwordHash    String?
  role            UserRole   @default(CUSTOMER)
  emailVerified   DateTime?
  // Email-based MFA — required for non-admin accounts; admin accounts exempt by policy.
  // mfaCodeHash holds a bcrypt hash of the most-recently-issued 6-digit code.
  mfaEnabled       Boolean    @default(false)
  mfaCodeHash      String?
  mfaCodeExpiresAt DateTime?
  mfaCodeAttempts  Int        @default(0)
  failedLoginCount Int        @default(0)
  lockedUntil      DateTime?
  lastLoginAt      DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  accounts        Account[]
  sessions        Session[]
  bookings        Booking[]
  leadNotes       LeadNote[]
  primaryWeddings Wedding[]  @relation("WeddingPrimaryClient")
  partnerWeddings Wedding[]  @relation("WeddingPartnerClient")
  messagesSent    WeddingMessage[]
}

// ─── Rental Items ─────────────────────────────────────────────────────────────

model RentalItem {
  id           String        @id @default(cuid())
  slug         String        @unique
  name         String
  tagline      String?
  description  String        @db.Text
  longDesc     String?       @db.Text
  price        Decimal       @db.Decimal(10, 2)
  depositPct   Int           @default(50)     // deposit percentage
  priceType    PriceType     @default(PER_EVENT)
  category     String        @default("general")
  images       String[]
  features     String[]
  dimensions   String?
  capacity     String?
  isActive     Boolean       @default(true)
  isFeatured   Boolean       @default(false)
  sortOrder    Int           @default(0)
  metaTitle    String?
  metaDesc     String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  bookingItems BookingItem[]
}

// ─── Bookings ─────────────────────────────────────────────────────────────────

model Booking {
  id              String        @id @default(cuid())
  bookingNumber   String        @unique @default(cuid())
  userId          String?
  user            User?         @relation(fields: [userId], references: [id])
  guestEmail      String?
  guestName       String?
  guestPhone      String?
  eventDate       DateTime
  eventEndDate    DateTime?
  setupTime       DateTime?
  eventType       String?
  venueName       String?
  venueAddress    String?
  venueCity       String?
  venueState      String?
  guestCount      Int?
  status          BookingStatus @default(PENDING)
  squareOrderId   String?
  squarePaymentId String?
  totalAmount     Decimal       @db.Decimal(10, 2)
  depositAmount   Decimal?      @db.Decimal(10, 2)
  paidAmount      Decimal       @default(0) @db.Decimal(10, 2)
  notes           String?       @db.Text
  adminNotes      String?       @db.Text
  googleEventId   String?
  cancelledAt     DateTime?
  cancelReason    String?
  items           BookingItem[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model BookingItem {
  id           String     @id @default(cuid())
  bookingId    String
  booking      Booking    @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  rentalItemId String
  rentalItem   RentalItem @relation(fields: [rentalItemId], references: [id])
  quantity     Int        @default(1)
  price        Decimal    @db.Decimal(10, 2)
  name         String
}

// ─── Settings ─────────────────────────────────────────────────────────────────

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  isSecret  Boolean  @default(false)
  label     String?
  group     String   @default("general")
  updatedAt DateTime @updatedAt
  updatedBy String?
}

// ─── Inquiries ────────────────────────────────────────────────────────────────

model Inquiry {
  id          String   @id @default(cuid())
  name        String
  email       String
  phone       String?
  eventDate   DateTime?
  eventType   String?
  message     String   @db.Text
  items       String[]
  isRead      Boolean  @default(false)
  repliedAt   DateTime?
  createdAt   DateTime @default(now())
}

// ─── Wedding Planning Leads ──────────────────────────────────────────────────

model WeddingPlanningLead {
  id              String     @id @default(cuid())
  name            String
  partnerName     String?
  email           String
  phone           String?
  weddingDate     DateTime?
  flexibleDate    Boolean    @default(false)
  guestCount      Int?
  venue           String?
  budget          String?
  planningType    String?
  servicesNeeded  String[]
  hearAboutUs     String?
  message         String?    @db.Text
  isRead          Boolean    @default(false)
  contactedAt     DateTime?
  status          LeadStatus @default(NEW)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt @default(now())
  notes           LeadNote[]
  consultations   Consultation[]
  wedding         Wedding?

  @@index([createdAt])
  @@index([status])
}

// ─── Lead Notes / Touchpoints ────────────────────────────────────────────────

model LeadNote {
  id         String              @id @default(cuid())
  leadId     String
  lead       WeddingPlanningLead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type       NoteType            @default(NOTE)
  body       String              @db.Text
  authorId   String?
  author     User?               @relation(fields: [authorId], references: [id])
  occurredAt DateTime            @default(now())
  createdAt  DateTime            @default(now())

  @@index([leadId])
}

// ─── Consultations (scheduled meetings with prospective couples) ─────────────

model Consultation {
  id            String               @id @default(cuid())
  leadId        String?
  lead          WeddingPlanningLead? @relation(fields: [leadId], references: [id], onDelete: SetNull)
  name          String
  email         String
  phone         String?
  scheduledAt   DateTime
  durationMin   Int                  @default(30)
  location      String?              // "Phone", "Video — Zoom", "In Person — Studio", etc.
  notes         String?              @db.Text
  status        ConsultationStatus   @default(REQUESTED)
  googleEventId String?
  reminderSentAt DateTime?
  cancelledAt   DateTime?
  cancelReason  String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@index([scheduledAt])
  @@index([status])
}

// ─── Wedding Workspace (created when a lead becomes a client) ────────────────

model Wedding {
  id               String          @id @default(cuid())
  leadId           String?         @unique
  lead             WeddingPlanningLead? @relation(fields: [leadId], references: [id], onDelete: SetNull)
  primaryClientId  String?
  primaryClient    User?           @relation("WeddingPrimaryClient", fields: [primaryClientId], references: [id])
  partnerClientId  String?
  partnerClient    User?           @relation("WeddingPartnerClient", fields: [partnerClientId], references: [id])
  partner1Name     String
  partner2Name     String?
  weddingDate      DateTime?
  ceremonyTime     DateTime?
  receptionTime    DateTime?
  venue            String?
  venueAddress     String?
  guestCount       Int?
  budgetTotal      Decimal?        @db.Decimal(10, 2)
  packageType      String?
  status           WeddingStatus   @default(PLANNING)
  notes            String?         @db.Text
  adminNotes       String?         @db.Text
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  tasks            WeddingTask[]
  vendors          WeddingVendor[]
  budgetItems      BudgetItem[]
  guests           Guest[]
  messages         WeddingMessage[]
  files            WeddingFile[]

  @@index([weddingDate])
  @@index([status])
}

model WeddingTask {
  id              String     @id @default(cuid())
  weddingId       String
  wedding         Wedding    @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  title           String
  description     String?    @db.Text
  category        String?
  milestone       String?    // e.g. "12_MONTHS", "9_MONTHS", "6_MONTHS", "3_MONTHS", "1_MONTH", "WEDDING_WEEK"
  dueDate         DateTime?
  status          TaskStatus @default(PENDING)
  assignedTo      String?
  sortOrder       Int        @default(0)
  visibleToCouple Boolean    @default(true)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([weddingId])
  @@index([dueDate])
}

model WeddingVendor {
  id         String       @id @default(cuid())
  weddingId  String
  wedding    Wedding      @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  name       String
  category   String
  contact    String?
  email      String?
  phone      String?
  website    String?
  status     VendorStatus @default(CONSIDERING)
  cost       Decimal?     @db.Decimal(10, 2)
  deposit    Decimal?     @db.Decimal(10, 2)
  paid       Decimal      @default(0) @db.Decimal(10, 2)
  notes      String?      @db.Text
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([weddingId])
}

model BudgetItem {
  id          String   @id @default(cuid())
  weddingId   String
  wedding     Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  category    String
  description String
  estimated   Decimal  @db.Decimal(10, 2)
  actual      Decimal? @db.Decimal(10, 2)
  paid        Decimal  @default(0) @db.Decimal(10, 2)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([weddingId])
}

model Guest {
  id          String     @id @default(cuid())
  weddingId   String
  wedding     Wedding    @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  firstName   String
  lastName    String?
  email       String?
  phone       String?
  partyName   String?
  rsvp        RSVPStatus @default(PENDING)
  rsvpToken   String?    @unique
  dietary     String?
  tableNumber Int?
  plusOne     Boolean    @default(false)
  notes       String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([weddingId])
}

model WeddingMessage {
  id        String   @id @default(cuid())
  weddingId String
  wedding   Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  body      String   @db.Text
  readAt    DateTime?
  createdAt DateTime @default(now())

  @@index([weddingId])
}

model WeddingFile {
  id          String   @id @default(cuid())
  weddingId   String
  wedding     Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  name        String
  url         String
  contentType String?
  sizeBytes   Int?
  uploadedBy  String?
  visibleToCouple Boolean @default(true)
  createdAt   DateTime @default(now())

  @@index([weddingId])
}

// ─── Time Off ────────────────────────────────────────────────────────────────
// Planner-controlled windows where customer bookings + consultations are
// blocked. Supports one-time or weekly-recurring blocks (e.g. "every Sunday").
//
// For one-time: startAt/endAt are the literal window.
// For weekly: startAt's date is when the recurrence begins, startAt/endAt
// times define the daily window (ignored when allDay), recurDays selects
// which weekdays the block applies to (0=Sun..6=Sat), and recurUntil ends
// the recurrence (null = forever).

enum TimeOffRecurrence {
  NONE
  WEEKLY
  MONTHLY
  YEARLY
}

model TimeOff {
  id         String            @id @default(cuid())
  reason     String?
  allDay     Boolean           @default(false)
  startAt    DateTime
  endAt      DateTime
  recurrence TimeOffRecurrence @default(NONE)
  recurDays  Int[]             @default([])
  recurUntil DateTime?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@index([startAt])
  @@index([recurUntil])
}

// ─── Email Marketing ─────────────────────────────────────────────────────────

model EmailTemplate {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  subject   String
  // Array of blocks: { kind: "heading"|"paragraph"|"image"|"button"|"divider"|"signature", ...fields }.
  // Rendered server-side into brand-styled HTML; supports {{name}} / {{email}} / {{first_name}} substitution.
  blocks    Json
  isPreset  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  sends     EmailSend[]

  @@index([updatedAt])
}

model EmailUnsubscribe {
  email          String   @id
  unsubscribedAt DateTime @default(now())
  source         String?  // template slug or "manual"
}

enum EmailSendStatus {
  SENT
  SKIPPED_UNSUBSCRIBED
  FAILED
}

model EmailSend {
  id             String          @id @default(cuid())
  templateId     String?
  template       EmailTemplate?  @relation(fields: [templateId], references: [id], onDelete: SetNull)
  templateName   String          // snapshot at send time
  recipientEmail String
  recipientName  String?
  subject        String
  status         EmailSendStatus
  error          String?
  sentAt         DateTime        @default(now())

  @@index([sentAt])
  @@index([recipientEmail])
  @@index([templateId])
}
